# Sao chep file nay thanh ".env" va dien API key cua ban
# Lay key tai: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Cong chay server (mac dinh 5173)
PORT=5173

# Model mac dinh (co the doi trong giao dien)
# claude-opus-4-8  (chat luong cao nhat)
# claude-sonnet-4-6 (nhanh, can bang)
SEOSHARK_MODEL=claude-sonnet-4-6
