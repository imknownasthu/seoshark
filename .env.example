# ====== SeoShark - Cau hinh mau (copy thanh .env hoac dat tren Render) ======
# TAT CA DEU TUY CHON. Mac dinh: engine Local + luu JSON + mail TEST mode.

# --- Cong ---
PORT=5173

# --- Engine AI (tuy chon) ---
# Gemini (key MIEN PHI: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
# Claude (tra phi)
ANTHROPIC_API_KEY=
SEOSHARK_MODEL=claude-sonnet-4-6

# --- Dang nhap ---
AUTH_ENABLED=true
MAIL_TO=imknownasthu@gmail.com

# --- Luu tai khoan vinh vien (tuy chon, NEN dat tren Render) ---
# Postgres free: Neon (https://neon.tech) hoac Supabase (https://supabase.com)
DATABASE_URL=

# --- Tu dong lay doi thu SERP cho tinh nang On-page (tuy chon) ---
# Tao tai: https://programmablesearchengine.google.com (cx) + https://developers.google.com/custom-search/v1/overview (key)
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=

# --- Gui mail (tuy chon) ---
# CACH 1 (KHUYEN DUNG): Brevo - free 300 mail/ngay, KHONG can domain.
# Dang ky https://www.brevo.com -> xac minh 1 email nguoi gui -> lay API key (Settings > SMTP & API > API Keys)
BREVO_API_KEY=
BREVO_SENDER=          # email nguoi gui da xac minh trong Brevo (vd 1 Gmail cua ban)
BREVO_SENDER_NAME=SeoShark

# CACH 2: Resend - free nhung CAN xac minh domain moi gui toi email bat ky
RESEND_API_KEY=
# RESEND_FROM=SeoShark <noreply@your-domain.com>

# CACH 2: Gmail SMTP - CHAY LOCAL duoc, nhung Render CHAN SMTP nen khong dung tren Render.
SMTP_USER=
SMTP_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
